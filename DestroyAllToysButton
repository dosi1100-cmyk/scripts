local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

function getNil(name, class)
    for _, v in next, getnilinstances() do
        if v.ClassName == class and v.Name == name then
            return v
        end
    end
end

local targetParent = LocalPlayer:WaitForChild("PlayerGui"):WaitForChild("MenuGui"):WaitForChild("Menu"):WaitForChild("TabContents"):WaitForChild("ToyDestroy")

if targetParent:FindFirstChild("DestroyAllButton") then
    targetParent.DestroyAllButton:Destroy()
end

local DestroyAllButton = Instance.new("TextButton")
DestroyAllButton.Name = "DestroyAllButton"
DestroyAllButton.Size = UDim2.new(0, 150, 0, 35)
DestroyAllButton.Position = UDim2.new(0.5, 0, 0, 70)
DestroyAllButton.AnchorPoint = Vector2.new(0.5, 0)
DestroyAllButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
DestroyAllButton.TextColor3 = Color3.fromRGB(255, 255, 255)
DestroyAllButton.Text = "Destroy All Toys"
DestroyAllButton.Font = Enum.Font.SourceSansBold
DestroyAllButton.TextSize = 16
DestroyAllButton.Parent = targetParent

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = DestroyAllButton

DestroyAllButton.MouseButton1Click:Connect(function()
    local folderName = LocalPlayer.Name .. "SpawnedInToys"
    local toyFolder = workspace:FindFirstChild(folderName)

    if toyFolder then
        local toys = toyFolder:GetChildren()
        
        for _, toy in ipairs(toys) do
            local args = {
                [1] = toy
            }
            ReplicatedStorage:WaitForChild("MenuToys"):WaitForChild("DestroyToy"):FireServer(unpack(args))
        end
    end
end)
