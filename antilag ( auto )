local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")

local plr = Players.LocalPlayer

local GrabEvents = ReplicatedStorage:WaitForChild("GrabEvents", 5)
if not GrabEvents then
    warn("GrabEvents를 찾을 수 없습니다. 해당 게임이 아닐 수 있습니다.")
    return
end

local CreateGrabLine = GrabEvents:WaitForChild("CreateGrabLine", 5)
if not CreateGrabLine then
    warn("CreateGrabLine 이벤트를 찾을 수 없습니다.")
    return
end

local Pline = CreateGrabLine.OnClientEvent

local antiLagEnabled = true
local antiLagMode = true
local AntiLagV = 27
local RapidFireLimit = 0.025
local CooldownTime = 2

local fireCount = {}
local isLagging = false
local suspectPlayer = nil
local connection = nil

local function AntiLagF()
    if connection then
        connection:Disconnect()
        connection = nil
    end

    local charBeamMove = plr:WaitForChild("PlayerScripts"):WaitForChild("CharacterAndBeamMove", 5)

    if not antiLagEnabled then
        if charBeamMove then charBeamMove.Enabled = true end
        return
    end

    if antiLagEnabled and not antiLagMode then
        if charBeamMove then charBeamMove.Enabled = false end
    end

    task.spawn(function()
        while true do
            task.wait(1)

            if not antiLagEnabled or not antiLagMode then continue end

            for fromPlr, data in pairs(fireCount) do
                data.count = 0 
            end
        end
    end)

    connection = Pline:Connect(function(fromPlr, ...)
        if typeof(fromPlr) ~= "Instance" or not fromPlr:IsA("Player") then return end
        if fromPlr == plr then return end

        if not antiLagEnabled then
            if charBeamMove then charBeamMove.Enabled = true end
            return
        end

        if not antiLagMode then
            if charBeamMove then charBeamMove.Enabled = false end
            return
        end

        if not fireCount[fromPlr] then
            fireCount[fromPlr] = {count = 0, lastCallTime = 0, isFlagged = false}
        end

        local currentTime = os.clock()
        local timeSinceLastCall = currentTime - fireCount[fromPlr].lastCallTime
        
        fireCount[fromPlr].lastCallTime = currentTime
        fireCount[fromPlr].count += 1

        if fireCount[fromPlr].count >= AntiLagV or timeSinceLastCall <= RapidFireLimit then
            if not fireCount[fromPlr].isFlagged then
                fireCount[fromPlr].isFlagged = true

                if not isLagging then
                    isLagging = true
                    suspectPlayer = fromPlr

                    pcall(function()
                        StarterGui:SetCore("SendNotification", {
                            Title = "[ 렉 감지 ]",
                            Text = fromPlr.Name .. " [ " .. fromPlr.DisplayName .. " ]",
                            Duration = 3
                        })
                    end)

                    if charBeamMove then charBeamMove.Enabled = false end

                    task.spawn(function()
                        local suspect = suspectPlayer

                        while suspect and suspect.Parent == Players do
                            local data = fireCount[suspect]
                            if not data then break end
                            
                            if os.clock() - data.lastCallTime >= CooldownTime then
                                data.isFlagged = false
                                break
                            end

                            task.wait(0.5)
                        end

                        isLagging = false
                        suspectPlayer = nil

                        if charBeamMove then charBeamMove.Enabled = true end
                    end)

                else
                    pcall(function()
                        StarterGui:SetCore("SendNotification", {
                            Title = "[ 추가 렉 감지 ]",
                            Text = fromPlr.Name .. " [ " .. fromPlr.DisplayName .. " ]",
                            Duration = 3
                        })
                    end)

                    task.spawn(function()
                        local suspect = fromPlr

                        while suspect and suspect.Parent == Players do
                            local data = fireCount[suspect]
                            if not data then break end
                            
                            if os.clock() - data.lastCallTime >= CooldownTime then
                                data.isFlagged = false
                                break
                            end

                            task.wait(0.5)
                        end
                    end)
                end
            end
        end
    end)
end

AntiLagF()

pcall(function()
    StarterGui:SetCore("SendNotification", {
        Title = "시스템",
        Text = "자동 안티 렉 작동 시작",
        Duration = 5
    })
end)
