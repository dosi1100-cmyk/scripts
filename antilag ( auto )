local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")
local RunService = game:GetService("RunService")

local plr = Players.LocalPlayer

local GrabEvents = ReplicatedStorage:WaitForChild("GrabEvents", 5)
if not GrabEvents then
    warn("GrabEvents를 찾을 수 없습니다. 해당 게임이 아닐 수 있습니다.")
    return
end

local CreateGrabLine = GrabEvents:WaitForChild("CreateGrabLine", 5)
if not CreateGrabLine then
    warn("CreateGrabLine 이벤트를 찾을 수 없습니다.")
    return
end

local Pline = CreateGrabLine.OnClientEvent

local antiLagEnabled = true
local antiLagMode = true
local AntiLagV = 25
local CooldownTime = 1
local MinFPS = 50

local fireCount = {}
local isLagging = false
local isFpsLow = false
local suspectPlayer = nil
local connection = nil
local globalFrame = 0

local charBeamMove = plr:WaitForChild("PlayerScripts"):WaitForChild("CharacterAndBeamMove", 5)

local function UpdateCharBeamState()
    if not charBeamMove then return end
    
    if not antiLagEnabled then
        charBeamMove.Enabled = true
        return
    end

    if not antiLagMode then
        charBeamMove.Enabled = false
        return
    end

    if isLagging or isFpsLow then
        charBeamMove.Enabled = false
    else
        charBeamMove.Enabled = true
    end
end

task.spawn(function()
    local frames = 0
    RunService.RenderStepped:Connect(function()
        frames += 1
        globalFrame += 1
    end)

    while true do
        task.wait(1)
        local currentFPS = frames
        frames = 0
        
        if currentFPS < MinFPS then
            if not isFpsLow then
                isFpsLow = true
                UpdateCharBeamState()
            end
        else
            if isFpsLow then
                isFpsLow = false
                UpdateCharBeamState()
            end
        end
    end
end)

local function AntiLagF()
    if connection then
        connection:Disconnect()
        connection = nil
    end

    UpdateCharBeamState()

    task.spawn(function()
        while true do
            task.wait(1)

            if not antiLagEnabled or not antiLagMode then continue end

            for fromPlr, data in pairs(fireCount) do
                data.count = 0 
            end
        end
    end)

    connection = Pline:Connect(function(fromPlr, ...)
        if typeof(fromPlr) ~= "Instance" or not fromPlr:IsA("Player") then return end
        if fromPlr == plr then return end

        if not antiLagEnabled or not antiLagMode then return end

        if not fireCount[fromPlr] then
            fireCount[fromPlr] = {count = 0, lastCallTime = 0, isFlagged = false, lastFrame = 0, frameBurst = 0}
        end

        local data = fireCount[fromPlr]

        if data.lastFrame == globalFrame then
            data.frameBurst += 1
            if data.frameBurst > 5 then
                return 
            end
        else
            data.lastFrame = globalFrame
            data.frameBurst = 1
        end

        local currentTime = os.clock()
        
        if data.lastCallTime ~= 0 and (currentTime - data.lastCallTime) <= 0.025 then
            data.count = AntiLagV
        end

        data.lastCallTime = currentTime
        data.count += 1

        if data.count >= AntiLagV then
            if not data.isFlagged then
                data.isFlagged = true

                if not isLagging then
                    isLagging = true
                    suspectPlayer = fromPlr
                    
                    UpdateCharBeamState()

                    pcall(function()
                        StarterGui:SetCore("SendNotification", {
                            Title = "[ 렉 감지 ]",
                            Text = fromPlr.Name .. " [ " .. fromPlr.DisplayName .. " ]",
                            Duration = 3
                        })
                    end)

                    task.spawn(function()
                        local suspect = suspectPlayer

                        while suspect and suspect.Parent == Players do
                            local sData = fireCount[suspect]
                            if not sData then break end
                            
                            if os.clock() - sData.lastCallTime >= CooldownTime then
                                sData.isFlagged = false
                                break
                            end

                            task.wait(0.5)
                        end

                        isLagging = false
                        suspectPlayer = nil
                        UpdateCharBeamState()
                    end)

                else
                    pcall(function()
                        StarterGui:SetCore("SendNotification", {
                            Title = "[ 추가 렉 감지 ]",
                            Text = fromPlr.Name .. " [ " .. fromPlr.DisplayName .. " ]",
                            Duration = 3
                        })
                    end)

                    task.spawn(function()
                        local suspect = fromPlr

                        while suspect and suspect.Parent == Players do
                            local sData = fireCount[suspect]
                            if not sData then break end
                            
                            if os.clock() - sData.lastCallTime >= CooldownTime then
                                sData.isFlagged = false
                                break
                            end

                            task.wait(0.5)
                        end
                    end)
                end
            end
        end
    end)
end

AntiLagF()

pcall(function()
    StarterGui:SetCore("SendNotification", {
        Title = "시스템",
        Text = "안티 렉 실행됨",
        Duration = 5
    })
end)
