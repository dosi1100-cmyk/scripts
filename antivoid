if _G.AntiVoidT == nil then
    _G.AntiVoidT = false
end

_G.AntiVoidT = not _G.AntiVoidT

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function ManagePlatform(enable)
    local existingPlatform = workspace:FindFirstChild("AntiVoidPlatform")
    if existingPlatform then
        existingPlatform:Destroy()
    end
    
    if enable then
        local platform = Instance.new("Part")
        platform.Name = "AntiVoidPlatform"
        platform.Size = Vector3.new(50000, 1, 50000)
        platform.Position = Vector3.new(0, -280, 0)
        platform.Anchored = true
        platform.Transparency = 1
        platform.CanCollide = true
        platform.Parent = workspace
    end
end

if _G.AntiVoidT then
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "AntiVoid",
        Text = "Anti Void가 켜졌습니다.",
        Duration = 2
    })
    
    workspace.FallenPartsDestroyHeight = -50000
    ManagePlatform(true)
    
    task.spawn(function()
        while _G.AntiVoidT do
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    if hrp.Position.Y < -330 then
                        hrp.CFrame = CFrame.new(0, -2, 0)
                        
                        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                        
                        hrp.Anchored = true
                        task.wait(0.03)
                        hrp.Anchored = false
                    end
                end
            end
            task.wait()
        end
        workspace.FallenPartsDestroyHeight = -330
    end)
else
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "AntiVoid",
        Text = "Anti Void가 꺼졌습니다.",
        Duration = 2
    })
    ManagePlatform(false)
end
