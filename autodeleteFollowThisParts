local TARGET_PLACE_ID = 6961824067

if game.PlaceId == TARGET_PLACE_ID then
    local mapFolder = workspace:FindFirstChild("Map")
    
    if mapFolder then
        local tweenedObjectsFolder = mapFolder:FindFirstChild("AlwaysHereTweenedObjects")
        
        if tweenedObjectsFolder then
            local oceanFolder = tweenedObjectsFolder:FindFirstChild("Ocean")
            
            for _, obj in ipairs(tweenedObjectsFolder:GetDescendants()) do
                if obj.Name == "FollowThisPart" then
                    local isInsideOcean = false
                    
                    if oceanFolder and obj:IsDescendantOf(oceanFolder) then
                        isInsideOcean = true
                    end
                    
                    if not isInsideOcean then
                        obj:Destroy()
                    end
                end
            end
        end
    end
end
