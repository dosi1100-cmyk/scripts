local Players = game:GetService("Players")
local TARGET_PLACE_ID = 6961824067

if game.PlaceId ~= TARGET_PLACE_ID then
	return
end

local TARGET_HIP_HEIGHT = 2
local CHECK_INTERVAL = 0.15

local R6_LEG_PARTS = {
	["Left Leg"] = true,
	["Right Leg"] = true,
}

local function allLegsGone(character)
	for partName in pairs(R6_LEG_PARTS) do
		local part = character:FindFirstChild(partName)
		if part and part:IsA("BasePart") then
			return false
		end
	end

	return true
end

local function allLegsPresent(character)
	for partName in pairs(R6_LEG_PARTS) do
		local part = character:FindFirstChild(partName)
		if not (part and part:IsA("BasePart")) then
			return false
		end
	end

	return true
end

local function disableAntiExplode()
	local function Notify(msg)
		game:GetService("StarterGui"):SetCore("SendNotification", {
			Title = "[ 💥 ] 폭발 무시",
			Text = msg,
			Duration = 3
		})
	end

	if not _G.AntiExplosionT then
		return
	end

	_G.AntiExplosionT = false

	if _G.AntiExplosionC then
		_G.AntiExplosionC:Disconnect()
		_G.AntiExplosionC = nil
	end

	if _G.AntiExplosionCharConn then
		_G.AntiExplosionCharConn:Disconnect()
		_G.AntiExplosionCharConn = nil
	end

	Notify("기능이 꺼졌습니다.")
end

local function watchCharacter(character)
	local humanoid = character:WaitForChild("Humanoid", 10)
	if not humanoid then
		return
	end

	if humanoid.RigType ~= Enum.HumanoidRigType.R6 then
		return
	end

	local antiExplodeFired = false

	local function turnOff()
		if antiExplodeFired then
			antiExplodeFired = false
			disableAntiExplode()
		end
	end

	humanoid.Died:Connect(function()
		turnOff()
	end)

	task.spawn(function()
		while character.Parent do
			if humanoid.Parent and humanoid.Health > 0 then
				if allLegsGone(character) then
					humanoid.HipHeight = TARGET_HIP_HEIGHT

					if not antiExplodeFired then
						antiExplodeFired = true
						loadstring(game:HttpGet('https://raw.githubusercontent.com/dosi1100-cmyk/scripts/refs/heads/main/antiexplode'))()
					end
				elseif allLegsPresent(character) then
					turnOff()
				end
			end

			task.wait(CHECK_INTERVAL)
		end
		turnOff()
	end)
end

local function onPlayerAdded(player)
	player.CharacterAdded:Connect(function(character)
		watchCharacter(character)
	end)

	if player.Character then
		watchCharacter(player.Character)
	end
end

Players.PlayerAdded:Connect(onPlayerAdded)

for _, player in ipairs(Players:GetPlayers()) do
	onPlayerAdded(player)
end
