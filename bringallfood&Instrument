-- 알림 전송 함수
local function SendNotify(msg)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "[ 시스템 ]",
            Text = msg,
            Duration = 3
        })
    end)
end

-- 이미 켜져 있는지 확인
if _G.AntiBananaT then
    SendNotify("모든 아이템 금지 모드가 이미 켜져 있습니다.")
    return
end

_G.AntiBananaT = true
SendNotify("모든 아이템 금지 모드가 켜졌습니다.")

-- 타겟 아이템 목록
local targetItemsDict = {
    ["CupMugWhite"] = true, ["CupMugBrown"] = true, ["FoodBanana"] = true, 
    ["FoodBread"] = true, ["FoodBroccoli"] = true, ["FoodCakePink"] = true, 
    ["FoodCoconut"] = true, ["FoodDippyEgg"] = true, ["FoodDonut"] = true, 
