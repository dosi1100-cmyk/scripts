-- Version: v1.0

if _G.ChamsToggle == nil then
    _G.ChamsToggle = false
end

-- 실행할 때마다 상태 반전 (토글)
_G.ChamsToggle = not _G.ChamsToggle

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- 연결된 이벤트를 관리하기 위한 테이블 (끌 때 정리용)
if not _G.ChamsConnections then
    _G.ChamsConnections = {}
end

-- 모든 ESP 초기화 함수
local function clearChams()
    -- 저장된 이벤트 연결 해제
    for _, connection in pairs(_G.ChamsConnections) do
        connection:Disconnect()
    end
    _G.ChamsConnections = {}
    
    -- 적용된 Highlight 제거
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character then
            local highlight = player.Character:FindFirstChild("ChamsESP_Highlight")
            if highlight then
                highlight:Destroy()
            end
        end
    end
end

-- 개별 캐릭터에 ESP 적용 함수
local function applyChams(character)
    if not _G.ChamsToggle then return end
    if not character then return end
    
    -- 이미 적용되어 있는지 확인
    if not character:FindFirstChild("ChamsESP_Highlight") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "ChamsESP_Highlight"
        highlight.FillColor = Color3.fromRGB(255, 0, 0) -- 빨간색 채우기
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- 흰색 테두리
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop -- 벽 너머로 보이게 하는 핵심 속성
        highlight.Parent = character
    end
end

-- 플레이어 처리 및 리스폰 감지 함수
local function handlePlayer(player)
    if player == LocalPlayer then return end -- 본인 제외
    
    if player.Character then
        applyChams(player.Character)
    end
    
    local conn = player.CharacterAdded:Connect(function(char)
        task.wait(0.5) -- 캐릭터가 완전히 로드될 때까지 대기
        applyChams(char)
    end)
    table.insert(_G.ChamsConnections, conn)
end

-- 토글 상태에 따른 실행
if _G.ChamsToggle then
    -- 현재 접속 중인 플레이어 적용
    for _, player in pairs(Players:GetPlayers()) do
        handlePlayer(player)
    end
    
    -- 새로 들어오는 플레이어 감지
    local joinConn = Players.PlayerAdded:Connect(handlePlayer)
    table.insert(_G.ChamsConnections, joinConn)
    
    -- 알림 시스템 (대부분의 실행기에서 지원)
    if setclipboard then
        print("Chams ESP: ON")
    end
else
    clearChams()
    if setclipboard then
        print("Chams ESP: OFF")
    end
end
