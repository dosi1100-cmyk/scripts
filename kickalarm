local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local plr = Players.LocalPlayer

local ifKickThenT = true
local anchoredCache = {}

local guiName = "AestheticKickNotify_Popup"
local existingGui = CoreGui:FindFirstChild(guiName)
if existingGui then
    existingGui:Destroy()
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = guiName
ScreenGui.ResetOnSpawn = false

if syn and syn.protect_gui then
    syn.protect_gui(ScreenGui)
    ScreenGui.Parent = CoreGui
elseif gethui then
    ScreenGui.Parent = gethui()
else
    ScreenGui.Parent = CoreGui
end

local Container = Instance.new("Frame")
Container.Name = "NotifyContainer"
Container.Size = UDim2.new(0, 320, 0.5, 0)
Container.Position = UDim2.new(0, 20, 0.5, 0)
Container.AnchorPoint = Vector2.new(0, 0)
Container.BackgroundTransparency = 1
Container.Parent = ScreenGui

local UIListLayout = Instance.new("UIListLayout")
UIListLayout.Parent = Container
UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
UIListLayout.VerticalAlignment = Enum.VerticalAlignment.Top
UIListLayout.Padding = UDim.new(0, 10)

local layoutOrderCount = 0
local notificationCount = 0 -- 알림 횟수 카운트용 변수 추가

local function CustomNotify(title, content, duration, isFriend)
    duration = duration or 5
    
    layoutOrderCount = layoutOrderCount - 1
    notificationCount = notificationCount + 1 -- 알림이 뜰 때마다 1씩 증가
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 65)
    frame.BackgroundColor3 = Color3.fromRGB(35, 35, 42)
    frame.BackgroundTransparency = 1
    frame.BorderSizePixel = 0
    frame.Active = true
    frame.LayoutOrder = layoutOrderCount
    frame.Parent = Container

    local frameCorner = Instance.new("UICorner")
    frameCorner.CornerRadius = UDim.new(0, 6)
    frameCorner.Parent = frame
    
    local uiStroke = Instance.new("UIStroke")
    uiStroke.Color = Color3.fromRGB(60, 60, 70)
    uiStroke.Thickness = 1.5
    uiStroke.Transparency = 1
    uiStroke.Parent = frame

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -20, 0, 22)
    titleLabel.Position = UDim2.new(0, 12, 0, 8)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    
    if isFriend then
        titleLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    else
        if title == "Script Loaded" then
            titleLabel.TextColor3 = Color3.fromRGB(120, 255, 140)
        else
            titleLabel.TextColor3 = Color3.fromRGB(255, 120, 120)
        end
    end
    
    titleLabel.TextTransparency = 1
    titleLabel.TextStrokeTransparency = 1
    titleLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    titleLabel.TextSize = 16
    titleLabel.Font = Enum.Font.GothamBlack
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = frame

    local contentLabel = Instance.new("TextLabel")
    contentLabel.Size = UDim2.new(1, -20, 0, 22)
    contentLabel.Position = UDim2.new(0, 12, 0, 32)
    contentLabel.BackgroundTransparency = 1
    contentLabel.Text = content
    
    if isFriend then
        contentLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    else
        contentLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
    
    contentLabel.TextTransparency = 1
    contentLabel.TextStrokeTransparency = 1
    contentLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    contentLabel.TextSize = 15
    contentLabel.Font = Enum.Font.GothamBold
    contentLabel.TextXAlignment = Enum.TextXAlignment.Left
    contentLabel.TextWrapped = true
    contentLabel.Parent = frame
    
    -- 우측 하단 카운트 텍스트 추가
    local countLabel = Instance.new("TextLabel")
    countLabel.Size = UDim2.new(0, 30, 0, 15)
    countLabel.Position = UDim2.new(1, -8, 1, -5)
    countLabel.AnchorPoint = Vector2.new(1, 1)
    countLabel.BackgroundTransparency = 1
    countLabel.Text = "#" .. tostring(notificationCount)
    countLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    countLabel.TextTransparency = 1
    countLabel.TextStrokeTransparency = 1
    countLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    countLabel.TextSize = 11
    countLabel.Font = Enum.Font.GothamBold
    countLabel.TextXAlignment = Enum.TextXAlignment.Right
    countLabel.Parent = frame
    
    local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    TweenService:Create(frame, tweenInfo, {BackgroundTransparency = 0.1}):Play()
    TweenService:Create(uiStroke, tweenInfo, {Transparency = 0}):Play()
    TweenService:Create(titleLabel, tweenInfo, {TextTransparency = 0, TextStrokeTransparency = 0.4}):Play()
    TweenService:Create(contentLabel, tweenInfo, {TextTransparency = 0, TextStrokeTransparency = 0.4}):Play()
    TweenService:Create(countLabel, tweenInfo, {TextTransparency = 0, TextStrokeTransparency = 0.4}):Play() -- 카운트 텍스트 등장 애니메이션
    
    task.delay(duration, function()
        local fadeOutInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        TweenService:Create(frame, fadeOutInfo, {BackgroundTransparency = 1}):Play()
        TweenService:Create(uiStroke, fadeOutInfo, {Transparency = 1}):Play()
        TweenService:Create(titleLabel, fadeOutInfo, {TextTransparency = 1, TextStrokeTransparency = 1}):Play()
        TweenService:Create(contentLabel, fadeOutInfo, {TextTransparency = 1, TextStrokeTransparency = 1}):Play()
        TweenService:Create(countLabel, fadeOutInfo, {TextTransparency = 1, TextStrokeTransparency = 1}):Play() -- 카운트 텍스트 퇴장 애니메이션
        task.wait(0.5)
        if frame then frame:Destroy() end
    end)
end

local function ifKickThenF()
    for _, otherPlr in ipairs(Players:GetPlayers()) do
        if otherPlr.Character then
            local hrp = otherPlr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                anchoredCache[otherPlr] = hrp.Anchored == true
            end
        end
    end

    Players.PlayerAdded:Connect(function(newPlr)
        newPlr.CharacterAdded:Connect(function(char)
            local hrp = char:WaitForChild("HumanoidRootPart", 5)
            if hrp then
                anchoredCache[newPlr] = false
            end
        end)
    end)

    Players.PlayerRemoving:Connect(function(leavingPlr)
        if anchoredCache[leavingPlr] == true then
            local DISP = leavingPlr.DisplayName
            local NAP = leavingPlr.Name
            local isFriend = false
            
            pcall(function()
                if plr ~= leavingPlr then
                    isFriend = plr:IsFriendsWith(leavingPlr.UserId)
                end
            end)
            
            CustomNotify("[ Kick Detected ]", "[" .. DISP .. "] (@" .. NAP .. ")", 8, isFriend)
        end
        anchoredCache[leavingPlr] = nil
    end)

    task.spawn(function()
        while ifKickThenT do
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character then
                    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        anchoredCache[p] = hrp.Anchored == true
                    end
                end
            end
            task.wait(0.3)
        end
    end)
end

ifKickThenF()

CustomNotify("Script Loaded", "Kick Notification Activated", 3, false)
