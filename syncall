local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function monitorHRP(character)
    local hrp = character:WaitForChild("HumanoidRootPart", 5)
    local humanoid = character:WaitForChild("Humanoid", 5)
    
    if hrp and humanoid then
        if hrp.Massless and not humanoid.Sit then
            hrp.Massless = false
        end
        
        hrp:GetPropertyChangedSignal("Massless"):Connect(function()
            if hrp.Massless and not humanoid.Sit then
                hrp.Massless = false
            end
        end)
        
        humanoid:GetPropertyChangedSignal("Sit"):Connect(function()
            if not humanoid.Sit and hrp.Massless then
                hrp.Massless = false
            end
        end)
    end
end

local function setupPlayer(player)
    if player == LocalPlayer then return end
    
    if player.Character then
        task.spawn(monitorHRP, player.Character)
    end
    
    player.CharacterAdded:Connect(function(character)
        task.spawn(monitorHRP, character)
    end)
end

for _, player in ipairs(Players:GetPlayers()) do
    setupPlayer(player)
end

Players.PlayerAdded:Connect(setupPlayer)
